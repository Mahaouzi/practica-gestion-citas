def sumar(a, b):
    return a + b

def restar(a, b):
    return a - b

def multiplicar(a, b):
    return a * b

def dividir(a, b):
    if b == 0:
        return "Error: división entre cero"
    return a / b

print("Suma:", sumar(4, 3))
print("Resta:", restar(10, 6))
print("Multiplicación:", multiplicar(5, 5))
print("División:", dividir(12, 4))
